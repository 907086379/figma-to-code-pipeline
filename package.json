{
    "name": "figma-to-code-pipeline",
    "version": "3.0.0",
    "description": "Figma link normalization, local cache index, validation, and Node CLI (framework-agnostic core).",
    "homepage": "https://github.com/907086379/figma-to-code-pipeline#readme",
    "keywords": [
        "figma",
        "cache",
        "cli",
        "design-tokens",
        "mcp"
    ],
    "license": "MIT",
    "engines": {
        "node": ">=16.20.0"
    },
    "bin": {
        "figma-cache": "bin/figma-cache.js"
    },
    "files": [
        "LICENSE",
        "bin",
        "cursor-bootstrap",
        "figma-cache/figma-cache.js",
        "figma-cache/js/*.js",
        "scripts/*.js",
        "scripts/*.cjs",
        "scripts/mobile/generate-mobile-spec.js",
        "scripts/mobile/field-mapping.template.json",
        "figma-cache/adapters/recipes/*.json",
        "figma-cache/docs/*.md",
        "figma-cache/docs/ui-1to1-report.schema.json",
        "figma-cache/docs/raw-json-extensions.schema.json"
    ],
    "publishConfig": {
        "registry": "https://registry.npmjs.org/"
    },
    "scripts": {
        "verify:cursor": "node scripts/check-cursor-shadow.js",
        "verify:cursor:sync": "node scripts/sync-cursor-shadow.js",
        "verify:docs": "node scripts/check-doc-encoding.js",
        "verify:static": "npm run verify:cursor && npm run verify:docs",
        "verify:pack": "node scripts/verify-npm-pack.js",
        "verify:shell": "node scripts/preflight-shell.js --warn",
        "verify:shell:strict": "node scripts/preflight-shell.js --strict",
        "test:node": "node tests/rules-guard.js && node tests/raw-derivatives.test.js && node tests/related-cache-keys.test.js && node tests/smoke.js",
        "test": "npm run verify:static && npm run test:node",
        "prepack": "npm run verify:static && node bin/figma-cache.js validate && npm run verify:pack",
        "pack:verify": "npm run verify:pack",
        "fc:normalize": "node bin/figma-cache.js normalize",
        "fc:get": "node bin/figma-cache.js get",
        "fc:upsert": "node bin/figma-cache.js upsert",
        "fc:ensure": "node bin/figma-cache.js ensure",
        "fc:validate": "node bin/figma-cache.js validate",
        "fc:stale": "node bin/figma-cache.js stale",
        "fc:budget": "node bin/figma-cache.js budget --mcp-only",
        "fc:backfill": "node bin/figma-cache.js backfill",
        "fc:repair-design-context-evidence": "node scripts/repair-mcp-design-context-evidence.cjs",
        "fc:init": "node bin/figma-cache.js init",
        "fc:config": "node bin/figma-cache.js config",
        "fc:flow:init": "node bin/figma-cache.js flow init",
        "fc:flow:add-node": "node bin/figma-cache.js flow add-node",
        "fc:flow:link": "node bin/figma-cache.js flow link",
        "fc:flow:chain": "node bin/figma-cache.js flow chain",
        "fc:flow:show": "node bin/figma-cache.js flow show",
        "fc:flow:mermaid": "node bin/figma-cache.js flow mermaid",
        "fc:cursor:init": "node bin/figma-cache.js cursor init",
        "fc:mobile:spec": "node scripts/mobile/generate-mobile-spec.js",
        "fc:merge-geometry": "node scripts/merge-figma-geometry-metrics.cjs",
        "fc:enrich": "node bin/figma-cache.js enrich",
        "fc:contract:check": "node bin/figma-cache.js contract-check",
        "fc:ui:preflight": "node scripts/ui-preflight.js",
        "fc:ui:audit": "node scripts/ui-1to1-audit.js",
        "fc:ui:report:aggregate": "node scripts/ui-report-aggregate.js",
        "fc:ui:accept": "node scripts/ui-auto-acceptance.js",
        "fc:ui:e2e:cross": "node scripts/cross-project-e2e.js",
        "fc:ui:gate": "npm run verify:static && npm run fc:ui:preflight && npm run fc:ui:audit -- --min-score=85 && npm run fc:validate && npm run test:node",
        "fc:ui:gate:pr": "npm run verify:static && npm run fc:ui:preflight && npm run fc:validate",
        "fc:ui:gate:main": "npm run verify:static && npm run fc:ui:preflight && npm run fc:ui:audit -- --min-score=90 && npm run fc:ui:report:aggregate && npm run fc:validate && npm run test:node"
    },
    "volta": {
        "node": "16.20.2"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/907086379/figma-to-code-pipeline.git"
    },
    "bugs": {
        "url": "https://github.com/907086379/figma-to-code-pipeline/issues"
    }
}
